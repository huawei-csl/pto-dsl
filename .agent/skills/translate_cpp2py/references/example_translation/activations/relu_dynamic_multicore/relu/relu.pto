module {
  func.func @sync_kernel_dyn(%arg0: !pto.ptr<f32>, %arg1: !pto.ptr<f32>, %arg2: i32) {
    pto.section.vector {
      %c0 = arith.constant 0 : index
      %c1 = arith.constant 1 : index
      %c32 = arith.constant 32 : index
      %0 = arith.index_cast %arg2 : i32 to index
      %1 = pto.get_block_num
      %2 = arith.index_cast %1 : i64 to index
      %3 = arith.ceildivsi %0, %2 : index
      %4 = pto.get_block_idx
      %5 = arith.index_cast %4 : i64 to index
      %6 = arith.muli %5, %3 : index
      %7 = arith.addi %6, %3 : index
      %8 = arith.minui %7, %0 : index
      %9 = arith.subi %8, %6 : index
      %10 = arith.ceildivsi %9, %c32 : index
      %11 = pto.make_tensor_view %arg0, shape = [%0], strides = [%c1] : !pto.tensor_view<?xf32>
      %12 = pto.make_tensor_view %arg1, shape = [%0], strides = [%c1] : !pto.tensor_view<?xf32>
      scf.for %arg3 = %c0 to %10 step %c1 {
        %13 = arith.muli %arg3, %c32 : index
        %14 = arith.addi %6, %13 : index
        %15 = arith.subi %8, %14 : index
        %16 = arith.minui %15, %c32 : index
        %17 = pto.alloc_tile valid_row = %c1 valid_col = %16 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
        %18 = pto.alloc_tile valid_row = %c1 valid_col = %16 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
        %19 = pto.partition_view %11, offsets = [%14], sizes = [%c32] : !pto.tensor_view<?xf32> -> !pto.partition_tensor_view<32xf32>
        %20 = pto.partition_view %12, offsets = [%14], sizes = [%c32] : !pto.tensor_view<?xf32> -> !pto.partition_tensor_view<32xf32>
        pto.tload ins(%19 : !pto.partition_tensor_view<32xf32>) outs(%17 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
        pto.trelu ins(%17 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%18 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
        pto.tstore ins(%18 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=32, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%20 : !pto.partition_tensor_view<32xf32>)
      }
    }
    return
  }
}

