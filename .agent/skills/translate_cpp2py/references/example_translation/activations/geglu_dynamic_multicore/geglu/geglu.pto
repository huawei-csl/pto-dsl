          %11 = arith.muli %7, %6 : i64
          %12 = arith.index_cast %11 : i64 to index
          %13 = arith.ceildivsi %0, %12 : index
          %14 = arith.muli %10, %13 : index
          %15 = arith.addi %14, %13 : index
